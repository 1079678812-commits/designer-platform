generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id        String   @id @default(cuid())
  name      String
  email     String   @unique
  password  String
  phone     String?
  avatar    String?
  role      String   @default("designer") // designer | client | admin
  title     String?
  bio       String?
  slug      String?  @unique // 公开主页路径，如 zhangsan
  status    String   @default("active")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  services        Service[]
  clients         Client[]
  orders          Order[]     @relation("DesignerOrders")
  contracts       Contract[]
  invoices        Invoice[]
  sentMessages    Message[]   @relation("SentMessages")
  receivedMessages Message[]  @relation("ReceivedMessages")
  notifications   Notification[]
  portfolios      Portfolio[]
}

model Service {
  id          String   @id @default(cuid())
  name        String
  description String?
  category    String
  price       Float
  status      String   @default("draft") // draft | active | inactive
  tags        String   @default("[]")
  orderCount  Int      @default(0)
  rating      Float    @default(0)
  coverImage  String?
  designerId  String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  designer User  @relation(fields: [designerId], references: [id], onDelete: Cascade)
  orders   Order[]
}

model Client {
  id        String   @id @default(cuid())
  name      String
  company   String?
  email     String
  phone     String?
  avatar    String?
  logo      String?   // 客户公司 Logo
  status    String   @default("active")
  designerId String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  designer User   @relation(fields: [designerId], references: [id], onDelete: Cascade)
  orders   Order[]
}

model Order {
  id          String    @id @default(cuid())
  orderNo     String    @unique
  title       String
  description String?
  status      String    @default("pending") // pending|confirmed|in_progress|review|completed|cancelled
  amount      Float
  progress    Int       @default(0)
  deadline    DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  clientId   String?
  designerId String
  serviceId  String?
  logo       String?   // 项目/公司 Logo（独立于客户）

  client   Client?  @relation(fields: [clientId], references: [id], onDelete: SetNull)
  designer User     @relation("DesignerOrders", fields: [designerId], references: [id], onDelete: Cascade)
  service  Service? @relation(fields: [serviceId], references: [id], onDelete: SetNull)
  contracts Contract[]
  invoices  Invoice[]
  items     OrderItem[]
}

model OrderItem {
  id        String  @id @default(cuid())
  orderId   String
  name      String  // 细分项目名称
  quantity  Int     @default(1)
  unitPrice Float   // 单价
  subtotal  Float   // 小计 (quantity * unitPrice)

  order Order @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@index([orderId])
}

model Contract {
  id          String    @id @default(cuid())
  title       String
  description String?
  status      String    @default("draft") // draft|signed|expired|cancelled
  amount      Float
  fileUrl     String?
  signedAt    DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  orderId    String
  designerId String

  order    Order @relation(fields: [orderId], references: [id], onDelete: Cascade)
  designer User  @relation(fields: [designerId], references: [id], onDelete: Cascade)
}

model Invoice {
  id        String    @id @default(cuid())
  invoiceNo String    @unique
  title     String
  amount    Float
  status    String    @default("pending") // pending|paid|overdue|cancelled
  issuedAt  DateTime  @default(now())
  dueDate   DateTime?
  paidAt    DateTime?
  fileUrl   String?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  orderId    String
  designerId String

  order    Order @relation(fields: [orderId], references: [id], onDelete: Cascade)
  designer User  @relation(fields: [designerId], references: [id], onDelete: Cascade)
}

model Message {
  id        String   @id @default(cuid())
  content   String
  read      Boolean  @default(false)
  createdAt DateTime @default(now())

  senderId   String
  receiverId String

  sender   User @relation("SentMessages", fields: [senderId], references: [id], onDelete: Cascade)
  receiver User @relation("ReceivedMessages", fields: [receiverId], references: [id], onDelete: Cascade)
}

model Notification {
  id        String   @id @default(cuid())
  title     String
  content   String?
  type      String   @default("system") // system|order|message|payment
  read      Boolean  @default(false)
  createdAt DateTime @default(now())

  userId String

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Portfolio {
  id          String   @id @default(cuid())
  title       String
  description String?
  coverUrl    String?
  images      String   @default("[]") // JSON array of image URLs
  category    String?
  link        String?
  sortOrder   Int      @default(0)
  designerId  String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  designer User @relation(fields: [designerId], references: [id], onDelete: Cascade)
}

model AuditLog {
  id        String   @id @default(cuid())
  userId    String?
  action    String   // create | update | delete | login | review | payment
  resource  String   // user | order | service | contract | invoice | payment
  resourceId String?
  detail    String?
  ip        String?
  createdAt DateTime @default(now())
}

model PasswordReset {
  id        String   @id @default(cuid())
  email     String
  token     String   @unique
  used      Boolean  @default(false)
  expiresAt DateTime
  createdAt DateTime @default(now())
}
